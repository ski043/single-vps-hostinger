{
	email {$LETSENCRYPT_EMAIL}
}

{$APP_DOMAIN} {
	encode gzip zstd

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	reverse_proxy app:3000 {
		header_up X-Real-IP {client_ip}
	}
}

{$STATUS_DOMAIN} {
	encode gzip zstd

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	reverse_proxy uptime-kuma:3001
}
